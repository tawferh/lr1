def main2():
    H = 1000
    W = 1000
    matr = np.zeros((H, W, 3), dtype=np.uint8)

    with open('model_1.obj', 'r') as file:
        list_v=[]
        for line in file:
            if line.startswith('v '):  # Обработка только строк с вершинами
                s = line.split()
                if s[0] == 'v':
                    list_v.append((float(s[1]), float(s[2]), float(s[3])))

    for v in list_v:
        x = int(50 * v[0] + 500)  # Шкалирование и смещение
        y = int(50 * v[1] + 500)
        if 0 <= x < W and 0 <= y < H:
            matr[y, x] = (255, 255, 255)  # Заливаем пиксель

    img = Image.fromarray(matr, 'RGB')
    img.save('vertices_frame.png')
    img.show()

