#2
def draw_line(image, x0, y0, x1, y1, count, color):
    # Алгоритм отрисовки линии
    step = 1.0/count
    for t in np.arange(0, 1 + step, step):  # Изменено на +step, чтобы включить последний момент
        x = round((1.0 - t) * x0 + t * x1)
        y = round((1.0 - t) * y0 + t * y1)
        if 0 <= x < image.shape[1] and 0 <= y < image.shape[0]:  # Ограничения по границам
            image[y, x] = color
